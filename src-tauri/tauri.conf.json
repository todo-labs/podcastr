{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Podcastr",
  "version": "0.1.0",
  "identifier": "com.podcastr.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Podcastr",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:podcastr.db"]
    }
  },
  "bundle": {
    "active": true
  }
}
